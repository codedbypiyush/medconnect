PORT=5000
NODE_ENV=development

# Neon / Render: paste full URL (keep ?sslmode=require)
DATABASE_URL=

# Optional local Postgres if you omit DATABASE_URL
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=medconnect_db

JWT_SECRET=

# Set either key variable. Backend auto-detects provider from key format.
OPENAI_API_KEY=
GROQ_API_KEY=
# Optional override (default: llama-3.1-8b-instant)
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
# Optional override (defaults to gemini-2.0-flash, then gemini-2.0-flash-lite)
GEMINI_MODEL=gemini-2.0-flash

# Comma-separated list supported (e.g. production + preview + local)
CLIENT_URL=http://localhost:5173
